---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Notion For Real Estate | The Complete Operating System for Agents" description="A complete Notion real estate operating system for agents — manage your entire business from first lead to closed deal.">
  <section style="padding:80px 0 48px;text-align:center;background:var(--color-surface);border-bottom:1px solid var(--color-border);">
    <div class="container">
      <div style="display:inline-block;padding:6px 16px;background:white;border:1px solid var(--color-border);border-radius:9999px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:24px;">Digital Product</div>
      <h1 style="font-size:clamp(32px,6vw,52px);font-weight:600;letter-spacing:-1px;line-height:1.1;margin-bottom:16px;">Notion For Real Estate</h1>
      <p style="font-size:18px;color:var(--color-text-secondary);max-width:560px;margin:0 auto 32px;line-height:1.6;">The complete operating system for real estate agents. Manage your entire business — from first lead to closed deal.</p>
      <a href="#pricing" class="btn btn--dark" style="font-size:16px;padding:16px 32px;">Get the Template</a>
    </div>
  </section>

  <section style="padding:64px 0;">
    <div class="container" style="max-width:720px;">
      <div class="prose">
        <h2>What This Is</h2>
        <p>A complete Notion workspace designed specifically for real estate agents. No more juggling spreadsheets, sticky notes, and random apps. Everything you need in one place.</p>

        <h2>What's Included</h2>
        <h3>Agent Dashboard</h3>
        <p>Your daily command center — see today's tasks, upcoming appointments, hot leads, and key metrics at a glance.</p>
        <h3>CRM Dashboard</h3>
        <p>Track every lead, client, and contact. Never lose track of a follow-up again. Built-in pipeline stages from first contact to closing.</p>
        <h3>Listings Dashboard</h3>
        <p>Manage all your property listings in one place. Track status, photos, showings, and offers.</p>
        <h3>Admin & Commissions Dashboard</h3>
        <p>Track your income, commissions, expenses, and business performance. Know exactly where you stand financially.</p>

        <h2>Core Databases (Fully Connected)</h2>
        <ul>
          <li><strong>Contacts</strong> — Every lead, client, and partner</li>
          <li><strong>Properties</strong> — All your listings with full details</li>
          <li><strong>Deals</strong> — Track every deal from offer to closing</li>
          <li><strong>Tasks</strong> — Never miss a follow-up or deadline</li>
          <li><strong>Appointments</strong> — Showings, meetings, and calls</li>
          <li><strong>Commissions</strong> — Income tracking and reporting</li>
        </ul>

        <h2>Who It's For</h2>
        <p>Built for solo agents and small teams who want to:</p>
        <ul>
          <li>Stop losing leads and follow-ups</li>
          <li>Have a clear view of their entire business</li>
          <li>Save hours on admin every week</li>
          <li>Look professional to clients</li>
          <li>Scale their business systematically</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="pricing" style="padding:64px 0;background:#111;color:white;text-align:center;">
    <div class="container">
      <h2 style="font-size:clamp(24px,4vw,36px);font-weight:600;letter-spacing:-0.5px;margin-bottom:16px;">Get Notion For Real Estate</h2>
      <p style="opacity:0.8;max-width:480px;margin:0 auto 32px;line-height:1.6;">One-time purchase. Lifetime access. Free updates.</p>
      <a href="#" class="btn btn--primary" style="font-size:16px;padding:16px 32px;">Buy Now</a>
      <p style="opacity:0.5;font-size:13px;margin-top:16px;">Secure payment via Stripe</p>
    </div>
  </section>
</BaseLayout>