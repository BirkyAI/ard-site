---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Notion For Real Estate | The Complete Operating System for Agents" description="The complete Notion workspace for real estate agents. Manage leads, listings, deals, and commissions in one place. One-time purchase, lifetime access.">
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Product","name":"Notion For Real Estate - The Complete Operating System","description":"A complete Notion workspace for real estate agents to manage their entire business","image":"/images/notion/The-Real-Estate-System-banner.jpg","brand":{"@type":"Brand","name":"Antigua Real Estate Development"},"offers":{"@type":"Offer","priceCurrency":"USD","price":"49","availability":"https://schema.org/InStock"}})} />

  <!-- HERO -->
  <section style="position:relative;min-height:60vh;display:flex;align-items:center;overflow:hidden;background:#0a0a0a;">
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0.3),rgba(0,0,0,0.7)),url('/images/notion/The-Real-Estate-System-banner.jpg');background-size:cover;background-position:center;"></div>
    <div class="container" style="position:relative;z-index:2;color:white;padding:80px 0;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);padding:6px 16px;border-radius:9999px;font-size:13px;font-weight:500;margin-bottom:24px;border:1px solid rgba(255,255,255,0.2);">📋 Digital Product</div>
      <h1 style="font-size:clamp(32px,7vw,56px);font-weight:600;line-height:1.1;letter-spacing:-1px;margin-bottom:24px;max-width:700px;margin-left:auto;margin-right:auto;">Notion For Real Estate</h1>
      <p style="font-size:clamp(16px,2.5vw,20px);line-height:1.6;opacity:0.9;max-width:560px;margin:0 auto 40px;">The complete operating system for real estate agents. Manage your entire business — from first lead to closed deal.</p>
      <div style="display:flex;flex-wrap:wrap;gap:16px;justify-content:center;">
        <a href="#pricing" class="btn btn--primary" style="font-size:18px;padding:18px 40px;">Get Instant Access →</a>
        <a href="#features" class="btn btn--outline" style="font-size:16px;padding:16px 32px;border-color:rgba(255,255,255,0.4);color:white;">See What's Inside</a>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section style="padding:32px 0;background:var(--color-surface);border-bottom:1px solid var(--color-border);">
    <div class="container">
      <div style="display:flex;justify-content:center;gap:48px;flex-wrap:wrap;text-align:center;">
        <div><div style="font-size:28px;font-weight:600;">500+</div><div style="font-size:13px;color:var(--color-text-muted);">Agents Using This</div></div>
        <div><div style="font-size:28px;font-weight:600;">4.9⭐</div><div style="font-size:13px;color:var(--color-text-muted);">Average Rating</div></div>
        <div><div style="font-size:28px;font-weight:600;">6</div><div style="font-size:13px;color:var(--color-text-muted);">Dashboards</div></div>
        <div><div style="font-size:28px;font-weight:600;">∞</div><div style="font-size:13px;color:var(--color-text-muted);">Lifetime Access</div></div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section style="padding:80px 0;">
    <div class="container" style="max-width:720px;text-align:center;">
      <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:3px;color:var(--color-text-muted);margin-bottom:16px;">The Problem</div>
      <h2 style="font-size:clamp(24px,4vw,36px);font-weight:600;letter-spacing:-0.5px;line-height:1.2;margin-bottom:24px;">Sound Familiar?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;text-align:left;">
        {[
          {icon:'😩',text:'Leads falling through the cracks because you forgot to follow up'},
          {icon:'📊',text:'Scattered data across spreadsheets, notebooks, and random apps'},
          {icon:'⏰',text:'Hours wasted on admin instead of closing deals'},
          {icon:'😰',text:'No clear view of your pipeline or upcoming tasks'},
          {icon:'💸',text:'Losing track of commissions and income'},
          {icon:'🤷',text:'Feeling disorganized and overwhelmed'},
        ].map(item => (
          <div style="display:flex;gap:12px;padding:16px;background:var(--color-surface);border-radius:12px;border:1px solid var(--color-border);">
            <span style="font-size:24px;">{item.icon}</span>
            <p style="font-size:14px;line-height:1.5;color:var(--color-text-secondary);margin:0;">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOLUTION -->
  <section style="padding:80px 0;background:var(--color-surface);">
    <div class="container" style="max-width:720px;text-align:center;">
      <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:3px;color:var(--color-text-muted);margin-bottom:16px;">The Solution</div>
      <h2 style="font-size:clamp(24px,4vw,36px);font-weight:600;letter-spacing:-0.5px;line-height:1.2;margin-bottom:16px;">One System. Everything Connected.</h2>
      <p style="font-size:17px;color:var(--color-text-secondary);line-height:1.7;margin-bottom:48px;">No more juggling tools. No more lost leads. Just a clean, powerful workspace that runs your entire real estate business.</p>
    </div>
  </section>

  <!-- DASHBOARDS GALLERY -->
  <section id="features" style="padding:80px 0;">
    <div class="container">
      <div class="section-header">
        <div class="section-label">What's Inside</div>
        <h2 class="section-title">6 Powerful Dashboards</h2>
        <p class="section-subtitle">Every dashboard is designed to give you instant clarity on your business.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:32px;">
        {[
          {img:'Agent Dashboard Cover.png',title:'Agent Dashboard',desc:'Your daily command center — tasks, appointments, hot leads, and key metrics at a glance.'},
          {img:'CRM Dashboard Cover.png',title:'CRM Dashboard',desc:'Track every lead and client. Pipeline stages from first contact to closing. Never lose a follow-up.'},
          {img:'Listings Dashboard Cover.png',title:'Listings Dashboard',desc:'Manage all your properties. Track status, photos, showings, and offers in one view.'},
          {img:'Admin Dashboard Cover.png',title:'Admin & Commissions',desc:'Income tracking, commission reports, expenses. Know exactly where you stand financially.'},
          {img:'Appointments Database Cover.png',title:'Appointments',desc:'Showings, meetings, calls — all scheduled and synced. Never double-book again.'},
          {img:'Start Here Header.png',title:'Start Here',desc:'Guided onboarding so you\'re up and running in minutes, not hours.'},
        ].map(item => (
          <div style="border-radius:16px;overflow:hidden;border:1px solid var(--color-border);background:white;transition:transform 0.3s,box-shadow 0.3s;">
            <div style="overflow:hidden;">
              <img src={`/images/notion/${item.img}`} alt={item.title} loading="lazy" style="width:100%;height:auto;display:block;transition:transform 0.3s;">
            </div>
            <div style="padding:20px;">
              <h3 style="font-size:17px;font-weight:600;margin-bottom:8px;">{item.title}</h3>
              <p style="font-size:14px;color:var(--color-text-secondary);line-height:1.6;margin:0;">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES LIST -->
  <section style="padding:80px 0;background:var(--color-surface);">
    <div class="container" style="max-width:720px;">
      <div class="section-header">
        <div class="section-label">Core Databases</div>
        <h2 class="section-title">Fully Connected. Zero Duplication.</h2>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        {[
          {icon:'👥',name:'Contacts',desc:'Every lead, client, and partner'},
          {icon:'🏠',name:'Properties',desc:'All listings with full details'},
          {icon:'🤝',name:'Deals',desc:'Track offer to closing'},
          {icon:'✅',name:'Tasks',desc:'Never miss a follow-up'},
          {icon:'📅',name:'Appointments',desc:'Showings, meetings, calls'},
          {icon:'💰',name:'Commissions',desc:'Income tracking & reports'},
        ].map(item => (
          <div style="display:flex;gap:12px;padding:16px;background:white;border-radius:12px;border:1px solid var(--color-border);">
            <span style="font-size:24px;">{item.icon}</span>
            <div>
              <div style="font-weight:600;font-size:15px;margin-bottom:2px;">{item.name}</div>
              <div style="font-size:13px;color:var(--color-text-secondary);">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section style="padding:80px 0;">
    <div class="container" style="max-width:720px;text-align:center;">
      <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:3px;color:var(--color-text-muted);margin-bottom:16px;">Perfect For</div>
      <h2 style="font-size:clamp(24px,4vw,36px);font-weight:600;letter-spacing:-0.5px;line-height:1.2;margin-bottom:32px;">Built for Agents Who Want to Level Up</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:16px;text-align:left;">
        {[
          'Stop losing leads and follow-ups',
          'Have a clear view of your entire business',
          'Save hours on admin every week',
          'Look professional to clients',
          'Scale your business systematically',
          'Work from anywhere — desktop or mobile',
        ].map(item => (
          <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--color-surface);border-radius:10px;border:1px solid var(--color-border);">
            <span style="color:#16a34a;font-size:18px;">✓</span>
            <span style="font-size:14px;font-weight:500;">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" style="padding:80px 0;background:#0a0a0a;color:white;">
    <div class="container" style="max-width:560px;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);padding:6px 16px;border-radius:9999px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:24px;border:1px solid rgba(255,255,255,0.2);">One-Time Purchase</div>
      <h2 style="font-size:clamp(28px,5vw,42px);font-weight:600;letter-spacing:-0.5px;margin-bottom:8px;">Get Notion For Real Estate</h2>
      <p style="opacity:0.7;max-width:480px;margin:0 auto 32px;line-height:1.6;">Lifetime access. Free updates forever. Use on unlimited devices.</p>
      
      <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.15);border-radius:20px;padding:40px;margin-bottom:32px;">
        <div style="font-size:56px;font-weight:700;margin-bottom:8px;">$49</div>
        <div style="opacity:0.6;font-size:14px;margin-bottom:24px;">USD · One-time payment</div>
        <a href="https://notionforrealestate.gumroad.com/l/ocuwss" class="btn btn--primary" style="font-size:18px;padding:18px 48px;width:100%;display:block;text-align:center;">Buy Now →</a>
        <div style="margin-top:20px;display:flex;justify-content:center;gap:24px;flex-wrap:wrap;">
          <span style="opacity:0.5;font-size:13px;">🔒 Secure Payment</span>
          <span style="opacity:0.5;font-size:13px;">⚡ Instant Access</span>
          <span style="opacity:0.5;font-size:13px;">↩️ 30-Day Guarantee</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:80px 0;">
    <div class="container" style="max-width:640px;">
      <div class="section-header">
        <div class="section-label">FAQ</div>
        <h2 class="section-title">Common Questions</h2>
      </div>
      <div style="display:grid;gap:16px;">
        {[
          {q:'What do I need to use this?',a:'Just a free Notion account. The template works on desktop, mobile, and web.'},
          {q:'Can I customize it?',a:'Absolutely! Everything is editable. Add fields, change views, make it yours.'},
          {q:'Do I get updates?',a:'Yes — lifetime free updates. As we improve the system, you get every update.'},
          {q:'Is there a refund policy?',a:'Yes, 30-day money-back guarantee. No questions asked.'},
          {q:'Can I use it for my team?',a:'Yes! Share it with your team in Notion. Works for solo agents and small teams.'},
        ].map(item => (
          <details style="padding:20px;background:var(--color-surface);border-radius:12px;border:1px solid var(--color-border);">
            <summary style="font-weight:600;font-size:15px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              {item.q}
              <span style="font-size:20px;opacity:0.4;">+</span>
            </summary>
            <p style="margin-top:12px;font-size:14px;color:var(--color-text-secondary);line-height:1.6;">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
