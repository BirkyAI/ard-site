---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Luna Jerney | Antigua Real Estate Development" description="Get in touch with Luna Jerney for real estate in Antigua Guatemala. Free consultation for expats and foreign buyers." image="/images/luna-jerney.jpg">
  <section class="page-hero">
    <div class="container">
      <div class="section-label">Contact</div>
      <h1 class="page-hero__title">Get in Touch</h1>
      <p class="page-hero__subtitle">Book a free consultation and let's discuss your property goals in Antigua Guatemala.</p>
    </div>
  </section>
  <section class="content-section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr;gap:48px;max-width:960px;margin:0 auto;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;">
          <div style="padding:32px;background:var(--color-surface);border-radius:16px;border:1px solid var(--color-border);">
            <h3 style="font-size:17px;font-weight:600;margin-bottom:8px;">WhatsApp</h3>
            <p style="font-size:14px;color:var(--color-text-secondary);margin-bottom:12px;">The fastest way to reach me</p>
            <a href="https://wa.me/50235716181" class="btn btn--dark" style="padding:10px 20px;font-size:14px;">Message on WhatsApp</a>
          </div>
          <div style="padding:32px;background:var(--color-surface);border-radius:16px;border:1px solid var(--color-border);">
            <h3 style="font-size:17px;font-weight:600;margin-bottom:8px;">Email</h3>
            <p style="font-size:14px;color:var(--color-text-secondary);margin-bottom:12px;">For detailed inquiries</p>
            <a href="mailto:info@antiguarealestatedevelopment.com" style="font-weight:500;">info@antiguarealestatedevelopment.com</a>
          </div>
          <div style="padding:32px;background:var(--color-surface);border-radius:16px;border:1px solid var(--color-border);">
            <h3 style="font-size:17px;font-weight:600;margin-bottom:8px;">Instagram</h3>
            <p style="font-size:14px;color:var(--color-text-secondary);margin-bottom:12px;">Follow for new listings</p>
            <a href="https://www.instagram.com/antiguarealestatedevelopment/" target="_blank" rel="noopener" style="font-weight:500;">@antiguarealestatedevelopment</a>
          </div>
        </div>
        <div style="background:var(--color-surface);border-radius:16px;border:1px solid var(--color-border);padding:48px;text-align:center;">
          <h2 style="font-size:24px;font-weight:600;margin-bottom:16px;">Book a Free Consultation</h2>
          <p style="font-size:16px;color:var(--color-text-secondary);margin-bottom:24px;max-width:480px;margin-left:auto;margin-right:auto;">Tell me about your property goals and I'll get back to you within 24 hours. No pressure, just honest advice.</p>
          <a href="https://wa.me/50235716181?text=Hi%20Luna!%20I'd%20like%20to%20book%20a%20free%20consultation%20about%20property%20in%20Antigua%20Guatemala" class="btn btn--dark" target="_blank" rel="noopener">Book via WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>