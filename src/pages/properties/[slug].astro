---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths() {
  const properties = await getCollection('properties');
  return properties.filter(p => p.data.lang !== 'es').map(p => ({ params: { slug: p.id }, props: p }));
}
const property = Astro.props;
const { Content } = await render(property);
const p = property.data;
const isRental = p.type === 'rental';
const displayPrice = p.priceLabel || (isRental ? `$${p.price.toLocaleString()}/month` : `$${p.price.toLocaleString()}`);
const metaDescription = `${p.title} in ${p.location}, Antigua Guatemala. ${p.beds ? p.beds + ' beds, ' : ''}${p.baths ? p.baths + ' baths, ' : ''}${p.area && p.area !== 'N/A' ? p.area + '. ' : ''}${displayPrice}.`;
---
<BaseLayout title={`${p.title} | Antigua Real Estate Development`} description={metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"RealEstateListing","name":p.title,"description":`${p.title} in ${p.location}, Antigua Guatemala`,"url":Astro.url.href,"image":p.image,"offers":{"@type":"Offer","price":p.price,"priceCurrency":"USD","priceSpecification": isRental ? {"@type":"UnitPriceSpecification","price":p.price,"priceCurrency":"USD","billingDuration":"P1M"} : undefined}})} />
  <section style="padding:48px 0;">
    <div class="container">
      <a href="/properties/" style="font-size:14px;color:var(--color-text-muted);font-weight:500;display:inline-flex;align-items:center;gap:4px;margin-bottom:24px;">← Back to Properties</a>
      <div style="display:grid;grid-template-columns:1fr;gap:32px;">
        <div style="border-radius:16px;overflow:hidden;box-shadow:var(--shadow-lg);">
          <img src={p.image} alt={p.alt} class="property-hero" style="width:100%;aspect-ratio:16/10;object-fit:cover;">
        </div>
        {p.gallery && p.gallery.length > 1 && (
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px;margin-top:16px;">
            {p.gallery.map((img, i) => (
              <div style="border-radius:8px;overflow:hidden;aspect-ratio:1;cursor:pointer;" onclick={`document.querySelector('.property-hero').src='${img}'`}>
                <img src={img} alt={`${p.title} - Photo ${i + 1}`} style="width:100%;height:100%;object-fit:cover;" loading="lazy">
              </div>
            ))}
          </div>
        )}
        <div>
          <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--color-text-muted);margin-bottom:4px;">{p.location}</div>
          <h1 style="font-size:clamp(28px,4vw,40px);font-weight:600;letter-spacing:-0.5px;line-height:1.1;margin-bottom:16px;">{p.title}</h1>
          <div style="font-size:clamp(28px,4vw,36px);font-weight:600;letter-spacing:-0.5px;margin-bottom:24px;">{displayPrice}</div>
          <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:32px;font-size:14px;color:var(--color-text-secondary);">
            {p.beds && <span style="padding:8px 16px;background:var(--color-surface);border-radius:8px;border:1px solid var(--color-border);">{p.beds} Bedrooms</span>}
            {p.baths && <span style="padding:8px 16px;background:var(--color-surface);border-radius:8px;border:1px solid var(--color-border);">{p.baths} Bathrooms</span>}
            {p.area && p.area !== 'N/A' && <span style="padding:8px 16px;background:var(--color-surface);border-radius:8px;border:1px solid var(--color-border);">{p.area}</span>}
            <span style={`padding:8px 16px;background:var(--color-surface);border-radius:8px;border:1px solid var(--color-border);${isRental ? 'color:#16a34a;font-weight:600;' : ''}`}>{p.status}</span>
          </div>
          <a href="/contact/" class="btn btn--dark" style="margin-bottom:48px;">{isRental ? 'Schedule a Viewing' : 'Inquire About This Property'}</a>
          <div class="prose"><Content /></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>