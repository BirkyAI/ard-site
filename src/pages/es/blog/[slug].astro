---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getTranslation } from '../../../i18n';
const t = getTranslation('es');
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.filter(p => p.data.lang === 'es').map(p => ({ params: { slug: p.id }, props: p }));
}
const post = Astro.props;
const { Content } = await render(post);
const d = post.data;
---
<BaseLayout locale="es" title={`${d.title} | Antigua Real Estate Development`} description={d.excerpt}>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":d.title,"description":d.excerpt,"image":d.image,"datePublished":d.date.toISOString(),"author":{"@type":"Person","name":"Luna Jerney"},"publisher":{"@type":"Organization","name":"Antigua Real Estate Development"}})} />
  <section style="padding:48px 0;">
    <div class="container">
      <a href="/es/blog/" style="font-size:14px;color:var(--color-text-muted);font-weight:500;display:inline-flex;align-items:center;gap:4px;margin-bottom:24px;">{t.labels.backToBlog}</a>
      <div style="max-width:720px;margin:0 auto;">
        <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--color-text-muted);margin-bottom:8px;">{d.tag}</div>
        <h1 style="font-size:clamp(28px,4vw,40px);font-weight:600;letter-spacing:-0.5px;line-height:1.1;margin-bottom:16px;">{d.title}</h1>
        <div style="font-size:14px;color:var(--color-text-muted);margin-bottom:32px;">{d.date.toLocaleDateString('es-GT', {year:'numeric',month:'long',day:'numeric'})}</div>
        <div style="border-radius:16px;overflow:hidden;margin-bottom:48px;">
          <img src={d.image} alt={d.alt} style="width:100%;aspect-ratio:16/10;object-fit:cover;">
        </div>
        <div class="prose"><Content /></div>
      </div>
    </div>
  </section>
</BaseLayout>
