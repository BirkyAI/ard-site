---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslation } from '../../../i18n';
const t = getTranslation('es');
const properties = (await getCollection('properties')).filter(p => !p.data.hidden && p.data.lang === 'es').sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const forSale = properties.filter(p => p.data.type !== 'rental');
const rentalsOrder = ['rental-barrios-coloniales-es', 'rental-barrios-coloniales-unfurnished-es', 'rental-apartment-contenta-el-hato-es', 'rental-casa-coi-el-hato-es', 'apartment-contentita-el-hato-es', 'studio-creativa-el-hato-es', 'rental-catarata-el-hato-es'];
const rentalsRaw = properties.filter(p => p.data.type === 'rental');
const rentals = [...rentalsOrder.map(id => rentalsRaw.find(p => p.id === id)).filter(Boolean), ...rentalsRaw.filter(p => !rentalsOrder.includes(p.id))];
---
<BaseLayout locale="es" title="Propiedades en Venta y Renta en Antigua Guatemala | Antigua Real Estate Development" description="Explora casas coloniales, terrenos, propiedades de inversión y alquileres en Antigua Guatemala. Asesoría experta para extranjeros y compradores internacionales." image="/images/properties/casas-massima-reforma/casas-massima-reforma-1.jpg">
  <section class="page-hero">
    <div class="container">
      <div class="section-label">{t.properties.label}</div>
      <h1 class="page-hero__title">{t.properties.title}</h1>
      <p class="page-hero__subtitle">{t.properties.subtitle}</p>
    </div>
  </section>

  {rentals.length > 0 && (
    <section class="content-section">
      <div class="container">
        <div class="section-header">
          <div class="section-label">{t.properties.rentLabel}</div>
          <h2 class="section-title">{t.properties.rentTitle}</h2>
          <p class="section-subtitle">{t.properties.rentSubtitle}</p>
        </div>
        <div class="grid-3">
          {rentals.map(p => (
            <a href={`/es/properties/${p.id}/`} class="property-card">
              <div class="property-card__image">
                <img src={p.data.image} alt={p.data.alt} loading="lazy" width="400" height="300">
                <div class="property-card__badge" style="background:#16a34a;">{p.data.badge}</div>
              </div>
              <div class="property-card__content">
                <div class="property-card__location">{p.data.location}</div>
                <h2 class="property-card__title">{p.data.title}</h2>
                <div class="property-card__details">
                  {p.data.beds && <span>{p.data.beds} {t.labels.beds}</span>}
                  {p.data.baths && <span>{p.data.baths} {t.labels.baths}</span>}
                  {p.data.area && <span>{p.data.area}</span>}
                </div>
                <div class="property-card__price">{p.data.priceLabel || `$${p.data.price.toLocaleString()}${t.labels.month}`}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="content-section">
    <div class="container">
      <div class="section-header">
        <div class="section-label">{t.properties.saleLabel}</div>
        <h2 class="section-title">{t.properties.saleTitle}</h2>
        <p class="section-subtitle">{t.properties.saleSubtitle}</p>
      </div>
      <div class="grid-3">
        {forSale.map(p => (
          <a href={`/es/properties/${p.id}/`} class="property-card">
            <div class="property-card__image">
              <img src={p.data.image} alt={p.data.alt} loading="lazy" width="400" height="300">
              <div class="property-card__badge">{p.data.badge}</div>
            </div>
            <div class="property-card__content">
              <div class="property-card__location">{p.data.location}</div>
              <h2 class="property-card__title">{p.data.title}</h2>
              <div class="property-card__details">
                {p.data.beds && <span>{p.data.beds} {t.labels.beds}</span>}
                {p.data.baths && <span>{p.data.baths} {t.labels.baths}</span>}
                {p.data.area && <span>{p.data.area}</span>}
              </div>
              <div class="property-card__price">${p.data.price.toLocaleString()}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
